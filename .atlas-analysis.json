  "projectType": "sdk-library",
  "projectName": "Bollard",
  "projectDescription": "An asynchronous Rust client library for the Docker and Podman daemon API, built on Hyper and Tokio with support for Unix sockets, Windows named pipes, HTTPS/SSL, SSH tunnels, WebSocket attach, and BuildKit.",
