  "keyFeatures": [
    "Async/await API built on Hyper and Tokio",
    "Docker and Podman first-class support",
    "Unix socket, Windows named pipe, HTTP, HTTPS (Rustls), and SSH transports",
    "BuildKit support via gRPC/protobuf for advanced image builds",
    "WebSocket container attach support",
    "Auto-discovery of Podman rootless sockets",
    "Docker context and DOCKER_HOST resolution",
    "API version negotiation",
    "Streaming responses as async Streams (stats, logs, build output)",
    "Serialization types generated from OpenAPI and protobuf specs"
  ],
